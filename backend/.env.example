# ── Database ─────────────────────────────────────────────────────
# Local:      mysql://root:password@localhost:3306/gebeya_b
# Aiven/Clever Cloud: paste the connection string from your provider
DATABASE_URL="mysql://user:password@host:port/gebeya_b"

# ── Auth ──────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── Frontend URL (set to your Vercel URL after deploy) ───────────
FRONTEND_URL="https://gebeya-b.vercel.app"
