# ── Database ─────────────────────────────────────────────────────
# Local:      mysql://root:password@localhost:3306/gebeya_b
# Aiven/Clever Cloud: paste the connection string from your provider
DATABASE_URL="mysql://user:password@host:port/gebeya_b"

# ── Auth ──────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── Frontend URL (set to your Vercel URL after deploy) ───────────
FRONTEND_URL="https://gebeya-b.vercel.app"

# ── Email Configuration (choose one method) ───────────────────
# Option 1: Resend API (recommended for production)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="gebeya-b@yourdomain.com"  # Must be verified in Resend dashboard

# Option 2: SMTP Configuration (alternative to Resend)
# For Gmail: Use an App Password, not your regular password
# Get App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="gebeya-b@yourdomain.com"

# Optional aliases supported by the backend for deployment platforms
# MAIL_HOST="smtp.gmail.com"
# MAIL_PORT="587"
# MAIL_USERNAME="your-email@gmail.com"
# MAIL_PASSWORD="your-app-password"
# MAIL_FROM="gebeya-b@yourdomain.com"
